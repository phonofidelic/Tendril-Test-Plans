# Copy to .env and fill in (never commit .env).
# Used by connect-cua-lume-macos-vm skill workflows on the host.

# Lume VM name from `lume ls`
LUME_VM_NAME=tendril-mac

# VM IP from `lume ls` (NAT address column)
LUME_VM_IP=192.168.64.2

# SSH user from VM: System Settings → General → Sharing → Remote Login
LUME_VM_SSH_USER=your-mac-user

# macOS account password for that user (host-only; do not commit)
LUME_VM_SSH_PASSWORD=

# Optional: pin a Tendril release for GUI install (e.g. 1.0.51 → releases/tag/v1.0.51)
# TENDRIL_VERSION=

# --- UTM Windows VM (connect-cua-utm-windows-vm skill) ---
# When CUA_HTTP_URL is set, cua-agent-app connects directly to that
# computer-server instead of the Lume VM above. Comment out to switch back.
# Must be the HTTP base URL (not ws://): the SDK's WebSocket transport speaks
# an older protocol than current computer-server.

# HTTP base URL of the in-guest computer-server: guest IP from `ipconfig`
# (Shared Network), or http://127.0.0.1:8000 with an Emulated VLAN port forward
# CUA_HTTP_URL=http://192.168.64.X:8000

# Display label for the remote VM (optional)
# CUA_VM_NAME=tendril-win
