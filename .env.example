# Copy to .env and fill in (never commit .env).
# Used by connect-cua-lume-macos-vm skill workflows on the host.

# Lume VM name from `lume ls`
LUME_VM_NAME=tendril-mac

# VM IP from `lume ls` (NAT address column)
LUME_VM_IP=192.168.64.2

# SSH user from VM: System Settings → General → Sharing → Remote Login
LUME_VM_SSH_USER=your-mac-user

# macOS account password for that user (host-only; do not commit)
LUME_VM_SSH_PASSWORD=

# Optional: pin a Tendril release for GUI install (e.g. 1.0.51 → releases/tag/v1.0.51)
# TENDRIL_VERSION=
